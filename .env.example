# 复制为 .env 并填入真实值。.env 不应提交到版本控制。

# 必填：从 Telegram @BotFather 获取的机器人 Token
TELEGRAM_BOT_TOKEN=

# 必填：用于加密数据库中存储的密码/授权码/OAuth token 的主密钥。
# 建议使用一个随机长字符串（如 openssl rand -hex 32 生成），一旦确定不要更换，
# 否则已加密存储的旧数据将无法解密。
MASTER_KEY=

# 必填：允许使用该机器人的 Telegram 用户 ID，逗号分隔（可通过 @userinfobot 等工具查看自己的 ID）
ALLOWED_TELEGRAM_USERS=

# 可选：SQLite 数据库文件路径，默认 ./mailbot.db
DB_PATH=

# 可选：Gmail OAuth2 登录（Device Code Flow）。需要在 Google Cloud Console 创建 OAuth 客户端
# （应用类型选择 "TVs and Limited Input devices" 以支持设备码流程）。
# 留空则 /addaccount 中不会出现 Gmail 的 OAuth 选项，仍可用应用专用密码添加 Gmail 账号。
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# 可选：Outlook/Microsoft OAuth2 登录（Device Code Flow）。需要在 Azure Portal 注册应用，
# API 权限勾选 IMAP.AccessAsUser.All、SMTP.Send、offline_access。
# 留空则 /addaccount 中不会出现 Outlook 的 OAuth 选项，仍可用应用专用密码添加 Outlook 账号。
OUTLOOK_OAUTH_CLIENT_ID=
OUTLOOK_OAUTH_CLIENT_SECRET=

# 可选：自定义 Telegram Bot API 基础 URL（例如本地 Bot API 服务器）。
# 程序会自动补齐路径为 <URL>/bot<token>/<method>。留空使用官方 https://api.telegram.org。
TELEGRAM_API_URL=

# 可选：Telegram Bot API 专用代理，支持 http://、https://、socks5://、socks5h://。
# 示例：socks5://127.0.0.1:1080 或 http://user:pass@proxy:8080
TELEGRAM_PROXY=

# 可选：全局代理，用于 OAuth token 刷新和 /update 检查 GitHub Releases。
# 支持协议同上。留空则相关请求走直连。
GLOBAL_PROXY=
